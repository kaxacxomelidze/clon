# Optional.
PORT=5000
APP_URL=
PUBLIC_APP_URL=https://www.clonyfy.com
# Optional: use this if share links should use a different host/subdomain.
SHARE_BASE_URL=
CLONYFY_PAGE_CAPTURE_TIMEOUT_MS=55000
CLONYFY_NAVIGATION_TIMEOUT_MS=25000
CLONYFY_STATIC_PAGE_TIMEOUT_MS=20000
CLONYFY_STATIC_ASSET_TIMEOUT_MS=6000
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
