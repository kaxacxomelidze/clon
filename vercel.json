{
  "version": 2,
  "buildCommand": "npm install --prefix packages/cloner --omit=dev",
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "public/**,templates/**,packages/cloner/dist/**,packages/cloner/templates/**,packages/cloner/node_modules/**,db.js",
      "excludeFiles": "output/**,packages/cloner/node_modules/**/{chromium-*,.cache,test,tests,.bin,*.md,*.ts,*.map}/**"
    }
  },
  "rewrites": [
    { "source": "/((?!_next/|favicon\\.|icon\\.png|icon\\.svg|clonyfy-logo\\.png|brand-mark\\.svg|brand-wordmark\\.svg).*)", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(clonyfy-logo\\.png|icon\\.(png|svg)|favicon\\.(ico|png)|brand-(mark|wordmark)\\.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
