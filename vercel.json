{
  "version": 2,
  "buildCommand": "npm install --prefix packages/cloner --omit=dev && npm run build --prefix packages/cloner",
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "public/**,templates/**,packages/cloner/dist/**,packages/cloner/templates/**,packages/cloner/node_modules/**,db.js",
      "excludeFiles": "output/**,packages/cloner/node_modules/**/{chromium-*,.cache,test,tests,.bin,*.md,*.ts,*.map}/**"
    }
  },
  "rewrites": [
    { "source": "/((?!_next/|favicon\\.|icon\\.|clonyfy-logo|brand-|.*\\.(?:css|js|png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|eot|mp4|webm|txt|json|map|xml)$).*)", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|eot|mp4|webm))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
